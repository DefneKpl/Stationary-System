@model IEnumerable<SmartStationerySystem.Models.QueueItem>

@{
    ViewData["Title"] = "Kuyruk";
}

<h1>Sipariş Kuyruğu</h1>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Sıra No</th>
            <th>Sipariş</th>
            <th>Müşteri</th>
            <th>Baskı Seçeneği</th>
            <th>Sipariş Durumu</th>
            <th>Kuyruğa Eklenme</th>
            <th>Tamamlandı mı?</th>
            <th>İşlemler</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>#@item.QueueNumber</td>

                <td>Sipariş #@item.OrderId</td>

                <td>@(item.Order?.Customer?.FullName ?? "-")</td>

                <td>
                    @(item.Order?.PrintOption != null
                        ? $"{item.Order.PrintOption.ColorType} - {item.Order.PrintOption.PaperSize}"
                        : "-")
                </td>

                <td>
                    @(item.Order?.Status ?? "-")
                </td>

                <td>@item.AddedTime.ToString("dd.MM.yyyy HH:mm")</td>

                <td>
                    @if (item.IsCompleted)
                    {
                        <span class="badge bg-success">Evet</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Hayır</span>
                    }
                </td>

                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info mb-1">Detay</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger mb-1">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>