@model IEnumerable<SmartStationerySystem.Models.Payment>

@{
    ViewData["Title"] = "Ödemeler";
}

<h1>Ödemeler</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Yeni Ödeme Oluştur</a>
</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Sipariş</th>
            <th>Müşteri</th>
            <th>Baskı Seçeneği</th>
            <th>Tutar</th>
            <th>Ödeme Yöntemi</th>
            <th>Ödeme Durumu</th>
            <th>Ödeme Tarihi</th>
            <th>İşlemler</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>Sipariş #@item.OrderId</td>

                <td>
                    @(item.Order?.Customer?.FullName ?? "-")
                </td>

                <td>
                    @(item.Order?.PrintOption != null
                        ? $"{item.Order.PrintOption.ColorType} - {item.Order.PrintOption.PaperSize}"
                        : "-")
                </td>

                <td>@item.Amount TL</td>

                <td>@item.PaymentMethod</td>

                <td>
                    @if (item.PaymentStatus == "Ödendi")
                    {
                        <span class="badge bg-success">Ödendi</span>
                    }
                    else if (item.PaymentStatus == "Beklemede")
                    {
                        <span class="badge bg-warning text-dark">Beklemede</span>
                    }
                    else if (item.PaymentStatus == "İptal")
                    {
                        <span class="badge bg-danger">İptal</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@item.PaymentStatus</span>
                    }
                </td>

                <td>@item.PaymentDate.ToString("dd.MM.yyyy HH:mm")</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning mb-1">Düzenle</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info mb-1">Detay</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger mb-1">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>