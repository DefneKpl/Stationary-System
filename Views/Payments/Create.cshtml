@model SmartStationerySystem.Models.Payment

@{
    ViewData["Title"] = "Ödeme Oluştur";
}

<h1>Ödeme Oluştur</h1>

<h4>Ödeme Bilgileri</h4>
<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="OrderId" class="control-label">Sipariş</label>
                <select asp-for="OrderId" class="form-control" asp-items="ViewBag.OrderId">
                    <option value="">Sipariş seçiniz</option>
                </select>
                <span asp-validation-for="OrderId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PaymentMethod" class="control-label">Ödeme Yöntemi</label>
                <select asp-for="PaymentMethod" class="form-control" asp-items="ViewBag.PaymentMethods">
                    <option value="">Ödeme yöntemi seçiniz</option>
                </select>
                <span asp-validation-for="PaymentMethod" class="text-danger"></span>
            </div>

            <div class="alert alert-info">
                Ödeme tutarı, ödeme durumu ve ödeme tarihi sistem tarafından otomatik oluşturulacaktır.
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Ödeme Oluştur" class="btn btn-primary" />
            </div>

        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Ödeme Listesine Dön</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}