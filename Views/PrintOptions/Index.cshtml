@model IEnumerable<SmartStationerySystem.Models.PrintOption>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ColorType)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PaperSize)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IsDoubleSided)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PricePerPage)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.ColorType)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PaperSize)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IsDoubleSided)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PricePerPage)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
